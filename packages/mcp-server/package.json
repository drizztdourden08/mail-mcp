{
  "name": "@mail-mcp/server",
  "version": "1.0.1",
  "description": "MCP server for AI-powered email access with provider-agnostic architecture.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc && node -e \"require('fs').cpSync('src/providers','dist/providers',{recursive:true,filter:(s)=>s.endsWith('.md')||require('fs').statSync(s).isDirectory()})\"",
    "copy-assets": "node -e \"require('fs').cpSync('src/providers','dist/providers',{recursive:true,filter:(s)=>s.endsWith('.md')||require('fs').statSync(s).isDirectory()})\""
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0"
  }
}
