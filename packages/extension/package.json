{
  "name": "mail-mcp-extension",
  "displayName": "Mail MCP",
  "description": "Give AI assistants secure, human-in-the-loop access to your email. Search, review, delete, move, and unsubscribe — all through an MCP server with a built-in approval UI.",
  "version": "1.0.2",
  "publisher": "Drizztdourden",
  "author": {
    "name": "Drizztdourden_",
    "url": "https://github.com/drizztdourden08"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/drizztdourden08/mail-mcp"
  },
  "homepage": "https://github.com/drizztdourden08/mail-mcp#readme",
  "bugs": {
    "url": "https://github.com/drizztdourden08/mail-mcp/issues"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "mcp",
    "email",
    "outlook",
    "exchange",
    "copilot",
    "ai",
    "mail",
    "model context protocol"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mail-mcp",
          "title": "Mail MCP",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "mail-mcp": [
        {
          "type": "webview",
          "id": "mail-mcp.panel",
          "name": "Mail MCP"
        }
      ]
    },
    "mcpServerDefinitionProviders": [
      {
        "id": "mail-mcp.server",
        "label": "Mail MCP Server"
      }
    ],
    "commands": [
      {
        "command": "mail-mcp.login",
        "title": "Mail MCP: Sign In"
      },
      {
        "command": "mail-mcp.openPanel",
        "title": "Mail MCP: Open Panel"
      },
      {
        "command": "mail-mcp.startServer",
        "title": "Mail MCP: Start Server"
      },
      {
        "command": "mail-mcp.stopServer",
        "title": "Mail MCP: Stop Server"
      },
      {
        "command": "mail-mcp.restartServer",
        "title": "Mail MCP: Restart Server"
      }
    ],
    "configuration": {
      "title": "Mail MCP",
      "properties": {
        "mail-mcp.clientId": {
          "type": "string",
          "default": "",
          "description": "The Application (client) ID from your Azure AD app registration. If not set, falls back to the MAIL_MCP_CLIENT_ID environment variable."
        },
        "mail-mcp.autoCopyCode": {
          "type": "boolean",
          "default": true,
          "description": "Automatically copy the device login code to clipboard when signing in via Copilot chat."
        },
        "mail-mcp.autoOpenBrowser": {
          "type": "boolean",
          "default": true,
          "description": "Automatically open the browser to the sign-in page when signing in via Copilot chat."
        },
        "mail-mcp.focusOnReview": {
          "type": "boolean",
          "default": true,
          "description": "Automatically focus the Mail panel when a new review list is created by Copilot."
        },
        "mail-mcp.customInstructions": {
          "type": "string",
          "default": "",
          "editPresentation": "multilineText",
          "description": "Custom instructions sent to the AI alongside the default MCP instructions. These take priority over defaults if contradictory."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "clean": "node -e \"fs=require('fs');p=require('path');d='out';fs.readdirSync(d).filter(f=>f!=='extension.js').forEach(f=>fs.unlinkSync(p.join(d,f)))\"",
    "bundle-server": "node esbuild-server.js",
    "copy-webview": "node -e \"const fs=require('fs');const p=require('path');fs.mkdirSync('dist/webview',{recursive:true});for(const f of fs.readdirSync('../webview/dist'))fs.copyFileSync(p.join('../webview/dist',f),p.join('dist/webview',f))\"",
    "compile": "npm run check-types && node esbuild.js && npm run bundle-server && npm run copy-webview",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --preserveWatchOutput",
    "package": "npm run check-types && node esbuild.js --production && npm run clean && node esbuild-server.js --production && npm run copy-webview"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.4",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.96.0",
    "esbuild": "^0.28.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.0"
  }
}
